generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  role               UserRole      @default(provider)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  isDisabled         Boolean       @default(false)
  mustChangePassword Boolean       @default(true)
  passwordHash       String?
  adminActions       AdminAction[]
  experts            Expert[]
  sessions           Session[]
}

model Expert {
  id                String                @id @default(cuid())
  email             String                @unique
  businessName      String
  slug              String                @unique
  tagline           String?
  shortDescription  String?
  overview          String?
  websiteUrl        String?
  phone             String?
  linkedinUrl       String?
  instagramUrl      String?
  facebookUrl       String?
  foundedYear       Int?
  hourlyRateMin     Int?
  hourlyRateMax     Int?
  minProjectBudget  Int?
  currencyCode      String                @default("USD")
  languages         String[]              @default([])
  industries        String[]              @default([])
  clientSizes       String[]              @default([])
  specialties       String[]              @default([])
  remoteFriendly    Boolean               @default(false)
  servesNationwide  Boolean               @default(false)
  responseTimeHours Int?
  featured          Boolean               @default(false)
  completionScore   Int                   @default(0)
  city              String                @db.Citext
  state             String                @db.Citext
  zip               String?
  rating            Float                 @default(0)
  verified          Boolean               @default(false)
  logo              String?
  services          String[]              @default([])
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  planTier          PlanTier              @default(free)
  userId            String?
  disabledReason    String?
  notes             String?
  status            ExpertStatus          @default(active)
  adminActions      AdminAction[]
  owner             User?                 @relation(fields: [userId], references: [id])
  projects          ExpertProject[]
  clients           ExpertClient[]
  media             ExpertMedia[]
  reviews           ExpertReview[]
  certifications    ExpertCertification[]
  awards            ExpertAward[]

  // Inquiry / lead records attached to this expert
  inquiries Inquiry[]

  @@index([status, createdAt])
  @@index([status, verified])
  @@index([status, city])
  @@index([status, rating])
  @@index([status, businessName])
  @@map("Provider")
}

model Session {
  /// Session token stored as primary key (opaque, random string)
  id        String   @id
  userId    String
  /// When this session expires
  expiresAt DateTime
  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

///
/// New: audit log of admin actions
model AdminAction {
  id          String          @id @default(cuid())
  adminUserId String?
  expertId    String          @map("providerId")
  type        AdminActionType
  metadata    Json?
  createdAt   DateTime        @default(now())
  admin       User?           @relation(fields: [adminUserId], references: [id])
  expert      Expert          @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId, createdAt])
}

enum UserRole {
  provider
  admin
}

enum PlanTier {
  free
  pro
}

///
/// Expert status used for moderation while preserving the existing DB enum mapping
enum ExpertStatus {
  pending
  active
  disabled

  @@map("ProviderStatus")
}

///
/// New: Admin action types for audit log
enum AdminActionType {
  APPROVE
  VERIFY_ON
  VERIFY_OFF
  DISABLE
  ENABLE
  EDIT
}

///
/// ✅ New: inquiry workflow status (MVP)
enum InquiryStatus {
  NEW
  READ
  ARCHIVED
}

///
/// Inquiry / lead submitted by a business owner to an expert
model Inquiry {
  id String @id @default(cuid())

  expertId String @map("providerId")
  expert   Expert @relation(fields: [expertId], references: [id], onDelete: Cascade)

  name    String
  email   String
  phone   String?
  message String

  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now())

  @@index([expertId, createdAt])
  @@index([status, createdAt])
}

model ExpertProject {
  id            String    @id @default(cuid())
  expertId      String    @map("providerId")
  title         String
  summary       String?
  challenge     String?
  solution      String?
  results       String?
  services      String[]  @default([])
  projectBudget Int?
  startedAt     DateTime?
  completedAt   DateTime?
  isFeatured    Boolean   @default(false)
  coverImageUrl String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expert        Expert    @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId, sortOrder, createdAt])
  @@index([expertId, isFeatured])
  @@map("ProviderProject")
}

model ExpertClient {
  id         String   @id @default(cuid())
  expertId   String   @map("providerId")
  name       String
  logoUrl    String?
  websiteUrl String?
  isFeatured Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expert     Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId, sortOrder, createdAt])
  @@index([expertId, isFeatured])
  @@map("ProviderClient")
}

model ExpertMedia {
  id        String          @id @default(cuid())
  expertId  String          @map("providerId")
  type      ExpertMediaType
  url       String
  altText   String?
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  expert    Expert          @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId, type, sortOrder, createdAt])
  @@map("ProviderMedia")
}

enum ExpertMediaType {
  logo
  cover
  gallery
  video

  @@map("ProviderMediaType")
}

model ExpertReview {
  id                  String    @id @default(cuid())
  expertId            String    @map("providerId")
  reviewerName        String
  company             String?
  rating              Float
  communicationRating Float?
  qualityRating       Float?
  valueRating         Float?
  title               String?
  body                String
  projectSummary      String?
  verified            Boolean   @default(false)
  source              String?
  publishedAt         DateTime?
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  expert              Expert    @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId, sortOrder, createdAt])
  @@index([expertId, verified, publishedAt])
  @@map("ProviderReview")
}

model ExpertCertification {
  id            String   @id @default(cuid())
  expertId      String   @map("providerId")
  title         String
  issuer        String
  year          Int?
  url           String?
  badgeImageUrl String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  expert        Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId, sortOrder, createdAt])
  @@map("ProviderCertification")
}

model ExpertAward {
  id            String   @id @default(cuid())
  expertId      String   @map("providerId")
  title         String
  issuer        String
  year          Int?
  url           String?
  badgeImageUrl String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  expert        Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId, sortOrder, createdAt])
  @@map("ProviderAward")
}
